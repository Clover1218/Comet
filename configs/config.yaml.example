node:
  id: "aasddas"                          # 留空则自动生成（基于主机名+MAC）
  name: "revloC"                        # 留空则使用主机名

network:
  listen_addr: "[::]"             # IPv6通配地址，接收所有网卡
  port: 9001
  discovery_enabled: true
  discovery_interval: 5        # mDNS广播间隔
  interface_name: "VirtualBox Host-Only Network"

# 传输设置
transfer:
  chunk_size: 2097152             # 2MB (字节)
  max_workers: 5                  # 并发上传分块数
  timeout: 30s                    # 单次操作超时时间
  max_retries: 3

storage:
  data_dir: "./data"              # 所有数据根目录
  downloads_dir: "downloads"      # 相对于 data_dir
  checkpoints_dir: "checkpoints"  # 断点记录目录
  queue_dir: "queue"              # 任务队列持久化目录
  peers_cache_dir: "peers"        # 节点缓存目录

# 安全设置
security:
  auth_mode: "token"              # "token" | "interactive" | "none"
  token: ""                       # 预共享密钥，auth_mode=token时必填
  token_file: ""                  # 白名单文件路径（可选）

# 日志设置
log:
  path: "./logs"
  level: "info"                   # debug | info | warn | error
  format: "text"                  # text | json
  output: "stdout"                # stdout | file | both
  max_size_mb: 100
  max_backups: 3
  max_age_days: 7